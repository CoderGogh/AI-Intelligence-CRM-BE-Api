{
  "analysis": {
    "analyzer": {

      "korean_index_analyzer": {
        "type": "custom",
        "tokenizer": "nori_mixed_tokenizer",
        "filter": [
          "nori_readingform",
          "lowercase",
          "synonym_index_filter",
          "stop_filter"
        ]
      },
      "korean_search_analyzer": {
        "type": "custom",
        "tokenizer": "nori_mixed_tokenizer",
        "filter": [
          "nori_readingform",
          "lowercase",
          "synonym_search_filter",
          "stop_filter"
        ]
      },

      "korean_analysis_index_analyzer": {
        "type": "custom",
        "tokenizer": "nori_discard_tokenizer",
        "filter": [
          "nori_readingform",
          "lowercase",
          "analysis_synonym_filter",
          "analysis_stop_filter"
        ]
      },
      "korean_analysis_search_analyzer": {
        "type": "custom",
        "tokenizer": "nori_discard_tokenizer",
        "filter": [
          "nori_readingform",
          "lowercase",
          "analysis_synonym_search_filter",
          "analysis_stop_filter"
        ]
      },

      "edge_ngram_index_analyzer": {
        "type": "custom",
        "tokenizer": "nori_mixed_tokenizer",
        "filter": [
          "nori_readingform",
          "lowercase",
          "edge_ngram_filter"
        ]
      }

    },
    "tokenizer": {

      "nori_mixed_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "mixed",
        "user_dictionary": "analysis/userdict.txt"
      },

      "nori_discard_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "discard",
        "user_dictionary": "analysis/analysis_userdict.txt"
      }

    },
    "filter": {

      "synonym_index_filter": {
        "type": "synonym",
        "synonyms_path": "analysis/synonyms.txt",
        "lenient": true
      },
      "synonym_search_filter": {
        "type": "synonym_graph",
        "synonyms_path": "analysis/synonyms.txt",
        "lenient": true
      },
      "stop_filter": {
        "type": "stop",
        "stopwords_path": "analysis/stopwords.txt",
        "ignore_case": true
      },

      "analysis_synonym_filter": {
        "type": "synonym",
        "synonyms_path": "analysis/analysis_synonyms.txt",
        "lenient": true
      },
      "analysis_synonym_search_filter": {
        "type": "synonym_graph",
        "synonyms_path": "analysis/analysis_synonyms.txt",
        "lenient": true
      },
      "analysis_stop_filter": {
        "type": "stop",
        "stopwords_path": "analysis/analysis_stopwords.txt",
        "ignore_case": true
      },

      "edge_ngram_filter": {
        "type": "edge_ngram",
        "min_gram": 2,
        "max_gram": 10,
        "token_chars": ["letter", "digit"]
      }

    }
  }
}
