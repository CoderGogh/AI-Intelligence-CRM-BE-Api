# =============================================================================
# CRM 백엔드 환경변수 템플릿
# =============================================================================
# 사용 방법:
#   1. 이 파일을 복사해서 .env 파일 생성 → cp .env.example .env
#   2. .env 파일은 절대 Git에 커밋하지 않는다 (.gitignore에 등록되어 있음)
#   3. 아래 값을 채운 후 IntelliJ Run Configuration > Environment variables에 입력
#
# IntelliJ 입력 형식 (세미콜론 구분):
#   GOOGLE_CLIENT_ID=xxx;GOOGLE_CLIENT_SECRET=xxx;JWT_SECRET=xxx
#
# 프로파일 전환:
#   로컬  → SPRING_PROFILES_ACTIVE=local  (기본값이므로 설정 불필요)
#   배포  → SPRING_PROFILES_ACTIVE=prod
# =============================================================================


# =============================================================================
# [로컬 개발 - application-local.yml 활성화]
# 아래 3개는 Google OAuth 실제 테스트 시에만 필요합니다.
# 일반 로그인 테스트만 할 경우 환경변수 없이 서버 실행 가능합니다.
# =============================================================================

# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급
# 형식: xxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Google Cloud Console에서 발급한 OAuth 2.0 클라이언트 시크릿
# ※ 절대 외부 노출 금지, 프론트엔드에 전달 금지
GOOGLE_CLIENT_SECRET=

# JWT 시크릿 키 (32자 이상)
# 로컬에서는 설정하지 않아도 기본값으로 동작합니다.
JWT_SECRET=ureca4-crm-local-dev-jwt-secret-key-32chars!!


# =============================================================================
# [프로덕션 배포 - application-prod.yml 활성화]
# SPRING_PROFILES_ACTIVE=prod 설정 시 아래 항목이 모두 필수입니다.
# =============================================================================

# 프로파일 활성화
# SPRING_PROFILES_ACTIVE=prod

# MySQL
# DB_URL=jdbc:mysql://<host>:<port>/crm?useSSL=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
# DB_USERNAME=
# DB_PASSWORD=

# MongoDB
# MONGODB_URI=mongodb://<host>:<port>/crm

# Redis
# REDIS_HOST=
# REDIS_PORT=6379

# Elasticsearch
# ES_URIS=http://<host>:9200

# Kafka
# KAFKA_SERVERS=<host>:9092

# Google OAuth (프로덕션용 - fallback 없음, 반드시 실제 값 입력)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# JWT (프로덕션용 - openssl rand -base64 32 으로 생성 권장)
# JWT_SECRET=
